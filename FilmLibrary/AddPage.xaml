<UserControl x:Class="FilmLibrary.AddPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FilmLibrary"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.Resources>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="BorderThickness" Value="1,1,1,1"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="5"/>
                <Setter Property="Padding" Value="10,0"/>
            </Style>
        </Grid.Resources>
        <Grid Grid.Column="0">
            <StackPanel>
                <TextBlock FontSize="20" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="10,10" Text="Добавление фильма/сериала"
                    Grid.Column="0"
                    Grid.Row="0"
        ></TextBlock>
                <TextBox x:Name="nameTextBox" ToolTip="Наименование фильма" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Название фильма" 
                          Margin="10,10" Padding="10, 0"
                          MinHeight="30"
                          Grid.Column="0" Grid.Row="1"
                         TextChanged="ValidateFields"
                   />
                <TextBox x:Name="imageTextBox" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         TextChanged="ImageText_TextChanged"
                         MaxWidth="700"
                    materialDesign:HintAssist.Hint="Изображение" Margin="10,10" Padding="10, 0"  MinHeight="30" Grid.Column="0" Grid.Row="1"/>
                <TextBox x:Name="descTextBox" ToolTip="Описание фильма" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    TextWrapping="Wrap"
                    AcceptsReturn="True"
                    MaxWidth="700"
                    VerticalScrollBarVisibility="Auto"
                         TextChanged="ValidateFields"
                    materialDesign:HintAssist.Hint="Описание фильма" Margin="10,10" Padding="10"  MinHeight="30" Grid.Column="0" Grid.Row="1"/>
                <TextBox x:Name="yearReleaseTextBox" ToolTip="Год выпуска" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                          TextChanged="ValidateFields"
                    materialDesign:HintAssist.Hint="Год выпуска" Margin="10,10" Padding="10, 0"  MinHeight="30" Width="110" HorizontalAlignment="Left" Grid.Column="0" Grid.Row="1"/>
                <TextBox x:Name="rateTextBox" ToolTip="Оценка фильма" Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    materialDesign:HintAssist.Hint="Оценка фильма" Margin="10,10" Padding="10, 0"  MinHeight="30" Width="110" HorizontalAlignment="Left"
                    Grid.Column="0" Grid.Row="1"
                          TextChanged="ValidateFields"
                    />
                <!--<TextBox x:Name="TextBox5" ToolTip="Категория" 
                    materialDesign:HintAssist.Hint="Категория" BorderThickness="1,1,1,1" HorizontalAlignment="Stretch"
                    materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
                    MinHeight="30"
                    Grid.Column="0"
                    Grid.Row="1"
                    Margin="10,10" Padding="10, 0" />-->
                <ComboBox x:Name="CategoryComboBox" Style="{StaticResource MaterialDesignComboBox}"
          SelectionChanged="ValidateFields"
          ToolTip="Категория"
          materialDesign:HintAssist.Hint="Категория"
          BorderThickness="1,1,1,1"
          HorizontalAlignment="Stretch"
          materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
          MinHeight="30"
          Margin="10,10"
          Padding="10,0">
                    <ComboBoxItem Content="Фильм" />
                    <ComboBoxItem Content="Сериал" />
                    <ComboBoxItem Content="Мультфильм" />
                    <ComboBoxItem Content="Документальный фильм" />
                </ComboBox>
                <Button x:Name="button1" Content="Создать"
                    Background="#FF2D57FF" Foreground="White" BorderThickness="0,0,0,0" Margin="0,10"  HorizontalAlignment="Center" VerticalAlignment="Bottom"  Width="206"
                    materialDesign:ButtonAssist.CornerRadius="10"
                        Click="addFilm_Click"
 />
            </StackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Image x:Name="image" Source="https://informburo.kz/storage/photos/94/main/Oh38ooVAU32ULU9c7rdUWZU2QoP4ojmlHrabANpL.jpg" Margin="0 70 10 0" VerticalAlignment="Top"/>
        </Grid>
    </Grid>
</UserControl>
