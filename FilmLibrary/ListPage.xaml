<UserControl x:Class="FilmLibrary.ListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FilmLibrary"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Margin="10">
            <TextBlock Text="Список фильмов/сериалов" FontSize="20" />
            <DataGrid x:Name="dataFilmsGrid" IsReadOnly="true"
                      MouseDoubleClick="dataFilmsGrid_MouseDoubleClick"
                      GridLinesVisibility="Horizontal"
          SelectionMode="Single"
                      AutoGenerateColumns="False"
                      MaxHeight="800"
                      VerticalScrollBarVisibility="Auto"
>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Изображение" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Image}" 
       Width="auto" Height="auto" 
       Stretch="UniformToFill"
       Margin="5"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="auto"/>
                    <DataGridTextColumn Header="Год выпуска" Binding="{Binding YearRelease}" Width="120"/>
                    <DataGridTextColumn Header="Оценка" Binding="{Binding Rate}" Width="80"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120"/>

                    <!-- Столбец с изображением -->
                    
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
        
    </Grid>
</UserControl>
