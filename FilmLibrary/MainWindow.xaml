<Window x:Class="FilmLibrary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:l="clr-namespace:FilmLibrary"
         xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Главная страница" Height="auto" Width="800">
    <Grid>
        <!--<Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>-->
        <StackPanel>
            <TextBlock FontSize="20" TextWrapping="Wrap" HorizontalAlignment="Left" Width="266" Margin="10,10"
                   Grid.Column="0"
                   Grid.Row="0"
                   >Главная страница</TextBlock>

            <TextBox x:Name="TextBox1" ToolTip="Наименование фильма" 
                   materialDesign:HintAssist.Hint="Название фильма" BorderThickness="1,1,1,1" HorizontalAlignment="Left" Width="523" 
                 materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
                MinHeight="30"
                 Grid.Column="0"

                 Grid.Row="1"
                   Margin="10,10" Grid.ColumnSpan="2" Grid.RowSpan="1" Padding="10, 0" >
            </TextBox>
            <TextBox x:Name="ImageText" ToolTip="Изображение" 
   materialDesign:HintAssist.Hint="Изображение" BorderThickness="1,1,1,1" HorizontalAlignment="Left" Width="523" 
 materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
MinHeight="30"
 Grid.Column="0"

 Grid.Row="1"
   Margin="10,10" Grid.ColumnSpan="2" Grid.RowSpan="1" Padding="10, 0" >
            </TextBox>
            <TextBox x:Name="TextBox2" ToolTip="Описание фильма" 
         materialDesign:HintAssist.Hint="Описание фильма" BorderThickness="1,1,1,1" HorizontalAlignment="Left" Width="523" 
       materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
                TextWrapping="Wrap"
  AcceptsReturn="True"
      MinHeight="30"
       Grid.Column="0"

       Grid.Row="1"
         Margin="10,10" Grid.ColumnSpan="2" Grid.RowSpan="1" Padding="10, 0" UseLayoutRounding="False" VerticalScrollBarVisibility="Auto" />
            <TextBox x:Name="TextBox3" ToolTip="Год выпуска" 
         materialDesign:HintAssist.Hint="Год выпуска" BorderThickness="1,1,1,1" HorizontalAlignment="Left" Width="523" 
       materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
      MinHeight="30"
       Grid.Column="0"

       Grid.Row="1"
         Margin="10,10" Grid.ColumnSpan="2" Grid.RowSpan="1" Padding="10, 0" >
            </TextBox>
            <TextBox x:Name="TextBox4" ToolTip="Оценка фильма" 
   materialDesign:HintAssist.Hint="Оценка фильма" BorderThickness="1,1,1,1" HorizontalAlignment="Left" Width="523" 
 materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
MinHeight="30"
 Grid.Column="0"

 Grid.Row="1"
   Margin="10,10" Grid.ColumnSpan="2" Grid.RowSpan="1" Padding="10, 0" >
            </TextBox>
            <TextBox x:Name="TextBox5" ToolTip="Категория" 
   materialDesign:HintAssist.Hint="Категория" BorderThickness="1,1,1,1" HorizontalAlignment="Left" Width="523" 
 materialDesign:TextFieldAssist.TextFieldCornerRadius="5"
MinHeight="30"
 Grid.Column="0"

 Grid.Row="1"
   Margin="10,10" Grid.ColumnSpan="2" Grid.RowSpan="1" Padding="10, 0" >
            </TextBox>
            <Button x:Name="button1" Content="Создать"
                Background="#FF2D57FF" Foreground="White" BorderThickness="0,0,0,0" Margin="0,10"  HorizontalAlignment="Center" VerticalAlignment="Bottom"  Width="206"
                materialDesign:ButtonAssist.CornerRadius="10"
            >
            </Button>
        </StackPanel>

    </Grid>

</Window>
